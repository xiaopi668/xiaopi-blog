---
import Layout from '../../../layouts/Layout.astro';
import PostCard from '../../../components/ui/PostCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, filterPostsByLang, getAllTags } from '../../../lib/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: 'zh' | 'en' };
const t = useTranslations(lang);
const allPosts = await getCollection('posts');
const posts = filterPostsByLang(allPosts, lang);
const tags = getAllTags(allPosts);
---

<Layout lang={lang} title={t('nav.posts')} description={t('site.description')}>
  <section class="mb-8">
    <h1 class="text-3xl font-bold mb-2">{t('nav.posts')}</h1>
    <div class="flex flex-wrap gap-2">
      <a
        href={`/${lang}/posts`}
        class="px-3 py-1 rounded-full text-sm font-medium transition-colors"
        style="background: var(--color-primary); color: white;"
      >
        All
      </a>
      {tags.map((tag) => (
        <a
          href={`/${lang}/tags?tag=${tag}`}
          class="px-3 py-1 rounded-full text-sm transition-colors"
          style="background: var(--border); color: var(--muted)"
        >
          #{tag}
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="grid gap-6">
      {posts.map((post) => (
        <PostCard post={post} lang={lang} />
      ))}
    </div>
    {posts.length === 0 && (
      <p class="text-center py-12" style="color: var(--muted)">{lang === 'zh' ? '暂无文章' : 'No posts yet'}</p>
    )}
  </section>
</Layout>
