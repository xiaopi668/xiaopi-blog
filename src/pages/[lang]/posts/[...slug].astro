---
import Layout from '../../../layouts/Layout.astro';
import Giscus from '../../../components/widgets/Giscus';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const lang = post.data.lang as 'zh' | 'en';
const t = useTranslations(lang);
const { Content } = await render(post);

const allPosts = await getCollection('posts');
const sameLangPosts = allPosts
  .filter((p) => p.data.lang === lang && !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentIndex = sameLangPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? sameLangPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sameLangPosts.length - 1 ? sameLangPosts[currentIndex + 1] : null;

const formattedDate = post.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.date.toISOString()}
  tags={post.data.tags}
  image={post.data.cover}
>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <a href={`/${lang}/posts`} class="text-sm hover:opacity-80 mb-4 inline-block" style="color: var(--muted)">
        ← {t('post.backToPosts')}
      </a>
      <h1 class="text-3xl font-bold mb-3">{post.data.title}</h1>
      <div class="flex items-center gap-3 text-sm" style="color: var(--muted)">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        {post.data.updated && (
          <>
            <span>·</span>
            <span>{t('post.updatedOn')} {post.data.updated.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}</span>
          </>
        )}
        {post.data.tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-1">
              {post.data.tags.map((tag: string) => (
                <span class="px-2 py-0.5 rounded-full text-xs" style="background: var(--border);">
                  #{tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    {post.data.cover && (
      <img src={post.data.cover} alt={post.data.title} class="w-full rounded-xl mb-8" />
    )}

    <div class="prose max-w-none">
      <Content />
    </div>

    <nav class="flex justify-between mt-12 pt-8 border-t" style="border-color: var(--border);">
      <div>
        {prevPost ? (
          <a href={`/${lang}/posts/${prevPost.id}`} class="text-sm hover:opacity-80" style="color: var(--muted)">
            ← {t('post.prev')}: {prevPost.data.title}
          </a>
        ) : null}
      </div>
      <div>
        {nextPost ? (
          <a href={`/${lang}/posts/${nextPost.id}`} class="text-sm hover:opacity-80" style="color: var(--muted)">
            {t('post.next')}: {nextPost.data.title} →
          </a>
        ) : null}
      </div>
    </nav>

    <div class="mt-12 pt-8 border-t" style="border-color: var(--border);">
      <Giscus lang={lang} client:only="react" />
    </div>
  </article>
</Layout>
