---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../lib/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: 'zh' | 'en' };
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('search.title')}>
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">{t('search.title')}</h1>
    <div id="search-container">
      <input
        id="search-input"
        type="search"
        placeholder={t('search.placeholder')}
        class="w-full px-4 py-3 rounded-xl border text-base outline-none focus:ring-2 transition-all"
        style="border-color: var(--border); background-color: var(--bg); color: var(--text);"
      />
      <div id="search-results" class="mt-6 space-y-4" />
    </div>
  </div>
</Layout>

<script>
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  function loadPagefindScript() {
    return new Promise((resolve) => {
      if (window.pagefind) return resolve(true);
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind.js';
      script.onload = () => resolve(true);
      script.onerror = () => resolve(false);
      document.head.appendChild(script);
    });
  }

  input?.addEventListener('input', async () => {
    const query = input.value.trim();
    if (!query) {
      if (results) results.innerHTML = '';
      return;
    }

    const loaded = await loadPagefindScript();
    if (!loaded || !window.pagefind) {
      if (results) results.innerHTML = '<p class="text-center py-8" style="color: var(--muted)">Search index not available</p>';
      return;
    }

    const search = await window.pagefind.search(query);
    if (results) results.innerHTML = '';

    if (!search.results.length) {
      if (results) results.innerHTML = '<p class="text-center py-8" style="color: var(--muted)">未找到相关文章</p>';
      return;
    }

    for (const result of search.results.slice(0, 20)) {
      const data = await result.data();
      const div = document.createElement('div');
      div.className = 'p-4 rounded-xl border transition-all hover:shadow-md';
      div.style.cssText = `border-color: var(--border); background-color: var(--bg);`;
      div.innerHTML = `
        <a href="${data.url}" class="block">
          <h3 class="font-semibold mb-1" style="color: var(--text)">${data.title}</h3>
          <p class="text-sm" style="color: var(--muted)">${data.excerpt}</p>
        </a>
      `;
      results?.appendChild(div);
    }
  });
</script>
