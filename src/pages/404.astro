---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../lib/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout lang={lang}>
  <div class="flex flex-col items-center justify-center py-24">
    <h1 class="text-6xl font-bold mb-4" style="color: var(--color-primary);">404</h1>
    <p class="text-xl mb-8" style="color: var(--muted);">{t('notFound.description')}</p>
    <a
      href={`/${lang}`}
      class="px-6 py-3 rounded-xl font-medium text-white transition-opacity hover:opacity-90"
      style="background-color: var(--color-primary);"
    >
      {t('notFound.backHome')}
    </a>
  </div>
</Layout>
