---
import { useTranslations } from '../../lib/i18n';

export interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="py-8 border-t mt-auto" style="border-color: var(--border);">
  <div class="max-w-4xl mx-auto px-4 text-center text-sm" style="color: var(--muted)">
    <p>{t('footer.copyright')}</p>
  </div>
</footer>
