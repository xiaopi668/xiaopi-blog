---
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../../lib/i18n';

export interface Props {
  post: CollectionEntry<'posts'>;
  lang: 'zh' | 'en';
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, date, tags, cover } = post.data;
const formattedDate = date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group rounded-xl border p-6 transition-all hover:shadow-lg" style="border-color: var(--border); background-color: var(--bg);">
  <a href={`/${lang}/posts/${post.id}`} class="block">
    {cover && (
      <img src={cover} alt={title} class="w-full h-48 object-cover rounded-lg mb-4" />
    )}
    <div class="flex items-center gap-2 text-xs mb-3" style="color: var(--muted)">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {tags.length > 0 && (
        <>
          <span>·</span>
          <div class="flex gap-1">
            {tags.map((tag) => (
              <span class="px-2 py-0.5 rounded-full text-xs" style="background: var(--border); color: var(--muted)">
                #{tag}
              </span>
            ))}
          </div>
        </>
      )}
    </div>
    <h2 class="text-xl font-semibold mb-2 group-hover:opacity-80 transition-opacity" style="color: var(--text)">
      {title}
    </h2>
    <p class="text-sm leading-relaxed" style="color: var(--muted)">
      {description}
    </p>
  </a>
</article>
