---
import { useTranslations } from '../../lib/i18n';
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<button
  id="theme-toggle"
  class="p-2 rounded-lg hover:opacity-80 transition-opacity cursor-pointer"
  style="color: var(--muted)"
  aria-label={t('theme.dark')}
>
  <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
    <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
  </svg>
  <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const sun = document.getElementById('sun-icon');
  const moon = document.getElementById('moon-icon');
  const html = document.documentElement;

  function updateIcons(isDark: boolean) {
    sun?.classList.toggle('hidden', !isDark);
    moon?.classList.toggle('hidden', isDark);
  }

  updateIcons(html.classList.contains('dark'));

  toggle?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateIcons(isDark);
  });
</script>
